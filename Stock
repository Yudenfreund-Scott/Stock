        ticker.setForeground(TEXT_PRIMARY);
        
        JLabel company = new JLabel(data[1]);
        company.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        company.setForeground(TEXT_SECONDARY);
        
        JLabel value = new JLabel(data[2]);
        value.setFont(new Font("Segoe UI", Font.BOLD, 12));
        value.setForeground(TEXT_PRIMARY);
        
        JLabel change = new JLabel(data[3]);
        change.setFont(new Font("Segoe UI", Font.BOLD, 12));
        change.setForeground(data[3].startsWith("+") ? GREEN : RED);
        
        row.add(ticker);
        row.add(company);
        row.add(value);
        row.add(change);
        
        return row;
    }
    
