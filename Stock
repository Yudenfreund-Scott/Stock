    private JPanel createNewsCard(String headline, String content, String source) {
        JPanel card = new JPanel();
        card.setLayout(new BoxLayout(card, BoxLayout.Y_AXIS));
        card.setBackground(Color.WHITE);
        card.setBorder(new CompoundBorder(
            new LineBorder(BORDER_LIGHT),
            new EmptyBorder(16, 16, 16, 16)
        ));
        
        JLabel headlineLabel = new JLabel(headline);
        headlineLabel.setFont(new Font("Segoe UI", Font.BOLD, 13));
        headlineLabel.setForeground(TEXT_PRIMARY);
        
        JLabel contentLabel = new JLabel("<html>" + content + "</html>");
        contentLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        contentLabel.setForeground(TEXT_SECONDARY);
        
        JLabel sourceLabel = new JLabel("Source: " + source);
        sourceLabel.setFont(new Font("Segoe UI", Font.ITALIC, 10));
        sourceLabel.setForeground(new Color(150, 150, 150));
        
        card.add(headlineLabel);
        card.add(Box.createVerticalStrut(8));
        card.add(contentLabel);
        card.add(Box.createVerticalStrut(8));
        card.add(sourceLabel);
        
        return card;
    }
    
