    private JPanel createPerformanceChart() {
        return new JPanel() {
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                Graphics2D g2d = (Graphics2D) g;
                g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                
                int width = getWidth();
                int height = getHeight();
                int padding = 60;
                int chartWidth = width - (padding * 2);
                int chartHeight = height - (padding * 2);
                
                g2d.setColor(Color.WHITE);
                g2d.fillRect(0, 0, width, height);
                
                g2d.setColor(BLACK_CHART);
                g2d.setStroke(new BasicStroke(2));
                g2d.drawLine(padding, padding, padding, height - padding);
                g2d.drawLine(padding, height - padding, width - padding, height - padding);
                
                g2d.setFont(new Font("Segoe UI", Font.BOLD, 12));
                g2d.setColor(TEXT_SECONDARY);
                g2d.drawString("YTD Performance Comparison", padding, 30);
                
                String[] labels = {"NVDA", "AMD", "CRWD", "PLTR", "SPY", "Portfolio"};
                double[] values = {18.5, 24.3, 12.8, 31.2, 13.2, 21.7};
                Color[] colors = {new Color(0, 100, 200), new Color(100, 0, 200), new Color(0, 150, 100), new Color(200, 100, 0), new Color(150, 150, 150), BLACK_CHART};
                
                int barWidth = chartWidth / (labels.length + 1);
                int maxValue = 35;
                
                for (int i = 0; i < labels.length; i++) {
                    int barHeight = (int)((values[i] / maxValue) * chartHeight);
                    int x = padding + (i * barWidth) + (barWidth / 4);
                    int y = height - padding - barHeight;
                    
                    g2d.setColor(colors[i]);
                    g2d.fillRect(x, y, barWidth / 2, barHeight);
                    
                    g2d.setColor(BLACK_CHART);
                    g2d.setFont(new Font("Segoe UI", Font.BOLD, 11));
                    g2d.drawString(labels[i], x, height - padding + 20);
                    
                    g2d.setFont(new Font("Segoe UI", Font.BOLD, 10));
                    g2d.drawString(values[i] + "%", x - 5, y - 5);
                }
                
                g2d.setColor(TEXT_SECONDARY);
                g2d.setFont(new Font("Segoe UI", Font.PLAIN, 10));
                g2d.drawString("% Gain", 10, padding - 10);
                
                drawLegend(g2d, width - 200, padding, labels, colors);
            }
            
            private void drawLegend(Graphics2D g2d, int x, int y, String[] labels, Color[] colors) {
                g2d.setFont(new Font("Segoe UI", Font.BOLD, 10));
                g2d.setColor(TEXT_PRIMARY);
                g2d.drawString("Legend:", x, y);
                
                for (int i = 0; i < labels.length; i++) {
                    g2d.setColor(colors[i]);
                    g2d.fillRect(x, y + 15 + (i * 18), 12, 12);
                    
                    g2d.setColor(TEXT_PRIMARY);
                    g2d.setFont(new Font("Segoe UI", Font.PLAIN, 10));
                    g2d.drawString(labels[i], x + 18, y + 24 + (i * 18));
                }
            }
        };
    }
    
